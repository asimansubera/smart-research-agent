{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Agent",
      "type": "debugpy",
      "request": "launch",
      "module": "agent.main",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Run MCP Server (standalone test)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/mcp_server/server.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "name": "Run Tests",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["tests/", "-v", "--tb=short"],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal"
    }
  ]
}
